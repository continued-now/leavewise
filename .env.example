# Kiwi.com (Tequila) — get API key at https://tequila.kiwi.com
# Used as the flight price data source
KIWI_API_KEY=
KIWI_AFFILIATE_ID=

# Travelpayouts — get your marker at https://www.travelpayouts.com
# Used for Aviasales flight links, Hotellook hotel links, and Jetradar compare links
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=

# Google Analytics 4 — get your Measurement ID at https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend — email capture + transactional emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_AUDIENCE_ID=your_audience_id

# KakaoTalk sharing — get your JavaScript app key at https://developers.kakao.com
NEXT_PUBLIC_KAKAO_APP_KEY=your_kakao_javascript_app_key

# Upstash Redis — distributed rate limiting (https://upstash.com)
# When both are set, API rate limits use Redis instead of in-memory counters.
# Leave blank for local dev (falls back to in-memory rate limiting).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin password — protects /blog/admin and other admin routes
ADMIN_PASSWORD=
